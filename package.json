{
  "name": "pi-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -c 'next dev -p ${DEV_PORT:-3001}'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --env-file=.env --test tests/smoke/*.test.mjs",
    "test:smoke": "node --env-file=.env --test tests/smoke/*.test.mjs",
    "test:db": "node --env-file=.env --test tests/smoke/database.test.mjs",
    "test:minio": "node --env-file=.env --test tests/smoke/minio.test.mjs",
    "test:health": "node --env-file=.env --test tests/smoke/health.test.mjs",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:runtime": "node scripts/seed-production.mjs",
    "storage:init": "node scripts/init-minio.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
