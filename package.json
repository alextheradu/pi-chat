    "idb": "^8.0.3",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.6.0",
    "marked": "^17.0.5",
    "minio": "^8.0.7",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.4",
