    "@tiptap/extension-italic": "^3.20.5",
    "@tiptap/extension-link": "^3.20.5",
    "@tiptap/extension-mention": "^3.20.5",
    "@tiptap/extension-paragraph": "^3.20.5",
    "@tiptap/extension-strike": "^3.20.5",
