# Application environment template
#
# Setup flow:
# 1. Copy this file to `.env`.
# 2. Fill in your team's values below.
# 3. Fill the required auth and secret values.
# 4. For local development:
#      docker compose -f docker-compose.dev.yml up -d
#      npx prisma migrate deploy
#      npx prisma db seed
#      npm run dev
# 5. For production, swap local hostnames for internal service names:
#      DATABASE_URL   → use `postgres` instead of `localhost`
#      MINIO_ENDPOINT → use `minio` instead of `localhost`
#      NEXTAUTH_URL / NEXT_PUBLIC_APP_URL / NEXT_PUBLIC_SOCKET_URL → your real chat domain
#      NODE_ENV       → production

# ── Branding / project identity ──────────────────────────────────────────────
# These values drive visible app copy and identity.
APP_NAME=TeamChat
TEAM_NAME=Your Team
TEAM_MEMBER_SINGULAR=Member
TEAM_MEMBER_PLURAL=Members

# ── App URLs / runtime ───────────────────────────────────────────────────────
# Local development defaults to port 3001 so it does not collide with other
# services. Override DEV_PORT if you need a different port.
DEV_PORT=3001
NEXTAUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
PORT=3000
NODE_ENV=development

# ── Auth / team policy ───────────────────────────────────────────────────────
# Required. Generate a secret with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# Required for Google OAuth.
# Create a Google Cloud OAuth app and add your callback URL:
#   http://localhost:3001/api/auth/callback/google
#   https://chat.yourteam.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The bootstrap admin account — automatically promoted to ADMIN on first sign-in.
ADMIN_EMAIL=admin@example.com

# Only Google accounts in this domain can sign in by default.
# Users outside this domain need an explicit admin invite.
ALLOWED_DOMAIN=example.com

# Email domain used for bot identities created by incoming webhooks.
BOT_EMAIL_DOMAIN=bots.teamchat.local

# ── Mobile app (Capacitor) ───────────────────────────────────────────────────
# Reverse-domain bundle ID for iOS/Android builds.
# Must be unique in the App Store / Google Play.
MOBILE_APP_ID=com.example.teamchat

# ── Theme / colors ───────────────────────────────────────────────────────────
# All values are optional — omit to keep the default Precision Dark palette.
# ACCENT_COLOR and ACCENT_HOVER control the primary brand color (yellow by default).
# The remaining values override background, border, and text shades.
#
# ACCENT_COLOR=#f5c518
# ACCENT_HOVER=#fcd73a
# BG_BASE=#0c0c0e
# BG_SURFACE=#111115
# BG_ELEVATED=#18181f
# BG_HOVER=#1e1e26
# BG_ACTIVE=#222230
# BORDER_SUBTLE=#1a1a22
# BORDER_DEFAULT=#2a2a34
# BORDER_STRONG=#3a3a48
# TEXT_PRIMARY=#f0f0f4
# TEXT_SECONDARY=#8b8b9a
# TEXT_MUTED=#52525e
# TEXT_INVERSE=#0c0c0e

# ── Database / Prisma / Docker dev Postgres ─────────────────────────────────
DATABASE_URL=postgresql://teamchat:changeme@localhost:5436/teamchat
POSTGRES_USER=teamchat
POSTGRES_PASSWORD=changeme

# ── File storage / MinIO ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9010
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_FILES=teamchat-files
MINIO_BUCKET_AVATARS=teamchat-avatars

# ── Realtime / Socket.io ────────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
SOCKET_PORT=3000

# ── Push notifications / PWA ─────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Email / invites ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Optional: Resend API key as an alternative to SMTP.
RESEND_API_KEY=
